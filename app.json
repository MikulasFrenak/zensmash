{
  "expo": {
    "name": "ZenSmash",
    "slug": "zensmash",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F6FBF7",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#F6FBF7",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "com.mikulasfrenak.zensmash",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mikulasfrenak.zensmash",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F6FBF7"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "experiments": {
      "baseUrl": ""
    },
    "plugins": [
      "expo-audio",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "7da7e437-e713-4ded-8898-5b94623fc1f1"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7da7e437-e713-4ded-8898-5b94623fc1f1"
    }
  }
}
