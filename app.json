{
  "expo": {
    "name": "ZenSmash",
    "slug": "zensmash",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F6FBF7",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#F6FBF7",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "com.mikulasfrenak.zensmash",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mikulasfrenak.zensmash",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F6FBF7"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "experiments": {
      "baseUrl": "/zensmash"
    },
    "plugins": [
      "expo-audio"
    ]
  }
}
